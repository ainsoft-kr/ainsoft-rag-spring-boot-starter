{
  "name": "spring-boot-demo-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "node ./scripts/run-playwright.mjs",
    "test:e2e:spec": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:server": "npm run build && cd ../.. && ./gradlew -Dmaven.repo.local=${MAVEN_REPO_LOCAL:-$HOME/.m2/repository} :spring-boot-demo:bootRun --args='--server.port=18080 --rag.indexPath=./spring-boot-demo/build/e2e-rag-index' -PskipFrontendBuild=true"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "svelte": "^5.53.11",
    "vite": "^8.0.0"
  }
}
